rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================
    // HELPERS
    // ===============================
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return hasUserProfile()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() in ['admin', 'superadmin'];
    }

    function isOwnUserProfile(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isOwnProfileCreate(userId) {
      return isOwnUserProfile(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoDataUrl',
          'xp',
          'actions',
          'periodActions',
          'badges',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && (!request.resource.data.keys().hasAny(['displayName']) || request.resource.data.displayName is string)
        && (!request.resource.data.keys().hasAny(['photoDataUrl']) || request.resource.data.photoDataUrl is string)
        && (!request.resource.data.keys().hasAny(['xp']) || request.resource.data.xp is number)
        && (!request.resource.data.keys().hasAny(['actions']) || request.resource.data.actions is map)
        && (!request.resource.data.keys().hasAny(['periodActions']) || request.resource.data.periodActions is map)
        && (!request.resource.data.keys().hasAny(['badges']) || request.resource.data.badges is list)
        && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt is timestamp)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp);
    }

    function isOwnProfileUpdate(userId) {
      return isOwnUserProfile(userId)
        && changedKeys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoDataUrl',
          'xp',
          'actions',
          'periodActions',
          'badges',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && (!changedKeys().hasAny(['displayName']) || request.resource.data.displayName is string)
        && (!changedKeys().hasAny(['photoDataUrl']) || request.resource.data.photoDataUrl is string)
        && (!changedKeys().hasAny(['xp']) || request.resource.data.xp is number)
        && (!changedKeys().hasAny(['actions']) || request.resource.data.actions is map)
        && (!changedKeys().hasAny(['periodActions']) || request.resource.data.periodActions is map)
        && (!changedKeys().hasAny(['badges']) || request.resource.data.badges is list)
        && (!changedKeys().hasAny(['createdAt']) || request.resource.data.createdAt is timestamp)
        && (!changedKeys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp);
    }

    function isNonIncreasingNumber(nextValue, currentValue) {
      return nextValue is number
        && currentValue is number
        && nextValue >= 0
        && nextValue <= currentValue;
    }

    function isPublicProductQuantityUpdate() {
      return changedKeys().hasOnly([
          'quantity',
          'stock',
          'stockQuantity',
          'availableQuantity',
          'availableStock',
          'inventory',
          'updatedAt'
        ])
        && changedKeys().hasAny([
          'quantity',
          'stock',
          'stockQuantity',
          'availableQuantity',
          'availableStock',
          'inventory'
        ])
        && (!changedKeys().hasAny(['quantity']) || isNonIncreasingNumber(request.resource.data.quantity, resource.data.quantity))
        && (!changedKeys().hasAny(['stock']) || isNonIncreasingNumber(request.resource.data.stock, resource.data.stock))
        && (!changedKeys().hasAny(['stockQuantity']) || isNonIncreasingNumber(request.resource.data.stockQuantity, resource.data.stockQuantity))
        && (!changedKeys().hasAny(['availableQuantity']) || isNonIncreasingNumber(request.resource.data.availableQuantity, resource.data.availableQuantity))
        && (!changedKeys().hasAny(['availableStock']) || isNonIncreasingNumber(request.resource.data.availableStock, resource.data.availableStock))
        && (!changedKeys().hasAny(['inventory']) || isNonIncreasingNumber(request.resource.data.inventory, resource.data.inventory))
        && (!changedKeys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp);
    }

    function isValidDefaultOrderPriceMode() {
      return !request.resource.data.keys().hasAny(['defaultOrderPriceMode'])
        || request.resource.data.defaultOrderPriceMode in ['retail', 'business'];
    }

    function isInventoryRecord() {
      return request.resource.data.date is string
        && request.resource.data.productId is string
        && request.resource.data.totalBaked is number
        && request.resource.data.totalBaked >= 0
        && request.resource.data.locked is bool
        && request.resource.data.updatedAt is timestamp;
    }

    function isPublicOrderCreate() {
      return request.resource.data.keys().hasOnly([
          'customerName',
          'customerPhone',
          'customerEmail',
          'customerAddress',
          'productId',
          'productName',
          'items',
          'quantity',
          'totalAmount',
          'subtotal',
          'selectedPriceMode',
          'notes',
          'status',
          'createdAt',
          'updatedAt',
          'orderDate',
          'source',
          'paymentMethod',
          'campaignId',
          'sessionId',
          'storeId',
          'companyId'
        ])
        && request.resource.data.customerName is string
        && request.resource.data.status == "reserved"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.keys().hasAny(['productId', 'items'])
        && (!request.resource.data.keys().hasAny(['productId']) || request.resource.data.productId is string)
        && (!request.resource.data.keys().hasAny(['productName']) || request.resource.data.productName is string)
        && (!request.resource.data.keys().hasAny(['items']) || request.resource.data.items is list)
        && (!request.resource.data.keys().hasAny(['quantity']) || (request.resource.data.quantity is number && request.resource.data.quantity > 0))
        && (!request.resource.data.keys().hasAny(['totalAmount']) || (request.resource.data.totalAmount is number && request.resource.data.totalAmount >= 0))
        && (!request.resource.data.keys().hasAny(['subtotal']) || (request.resource.data.subtotal is number && request.resource.data.subtotal >= 0))
        && (!request.resource.data.keys().hasAny(['selectedPriceMode']) || request.resource.data.selectedPriceMode in ['retail', 'business'])
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp)
        && (!request.resource.data.keys().hasAny(['customerPhone']) || request.resource.data.customerPhone is string)
        && (!request.resource.data.keys().hasAny(['customerEmail']) || request.resource.data.customerEmail is string)
        && (!request.resource.data.keys().hasAny(['customerAddress']) || request.resource.data.customerAddress is string)
        && (!request.resource.data.keys().hasAny(['notes']) || request.resource.data.notes is string)
        && (!request.resource.data.keys().hasAny(['source']) || request.resource.data.source is string)
        && (!request.resource.data.keys().hasAny(['paymentMethod']) || request.resource.data.paymentMethod is string)
        && (!request.resource.data.keys().hasAny(['campaignId']) || request.resource.data.campaignId is string)
        && (!request.resource.data.keys().hasAny(['sessionId']) || request.resource.data.sessionId is string)
        && (!request.resource.data.keys().hasAny(['storeId']) || request.resource.data.storeId is string)
        && (!request.resource.data.keys().hasAny(['companyId']) || request.resource.data.companyId is string);
    }

    // ===============================
    // PUBLIC / CMS CONTENT
    // ===============================
    match /pages/{id} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /products/{id} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || isPublicProductQuantityUpdate();
      allow delete: if false;
    }

    match /categories/{id} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /banners/{id} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /campaigns/{campaignId}/{document=**} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /campaign_events/{eventId} {
      allow create: if
        request.resource.data.campaignId is string &&
        request.resource.data.sessionId is string &&
        request.resource.data.timestamp != null &&
        request.resource.data.actionType is string;

      allow read: if true;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // PUBLIC STOREFRONT CONFIG
    // ===============================
    match /storefront_configs/{companyId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /product_collections/{collectionId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /storefront_events/{eventId} {
      allow create: if
        request.resource.data.companyId is string &&
        request.resource.data.actionType is string &&
        request.resource.data.sessionId is string &&
        request.resource.data.timestamp != null;

      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // DAILY INVENTORY
    // ===============================
    match /inventory/{dateId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isInventoryRecord();
      allow delete: if false;
    }

    // ===============================
    // INVENTORY TEMPLATES
    // ===============================
    match /inventory_templates/{templateId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // PAYMENT METHODS
    // ===============================
    match /payment_methods/{methodId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // AUDIT LOGS
    // ===============================
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ===============================
    // ORDERS
    // ===============================
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow delete: if false;

      allow create, update: if isAdmin();

      allow create: if isPublicOrderCreate();

      allow update: if
        isAdmin()
        ||
        (
          request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['receiptUrl', 'status'])
          && request.resource.data.status == "pending_verification"
        );
    }

    // ===============================
    // ORDER ARCHIVE
    // ===============================
    match /orders_archive/{orderId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // PAYMENT REQUESTS
    // ===============================
    match /paymentRequests/{paymentId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.orderId is string
        && request.resource.data.amount is number
        && request.resource.data.qrProvider is string
        && request.resource.data.status == "waiting"
        && request.resource.data.createdAt is timestamp;

      allow update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // INVOICES
    // ===============================
    match /invoices/{invoiceId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.orderId is string
        && request.resource.data.totalAmount is number
        && request.resource.data.createdAt is timestamp
        && request.resource.data.invoiceNumber is string
        && request.resource.data.items is list;

      allow update: if
        isAdmin()
        ||
        (
          request.resource.data.secureToken is string
          && resource.data.secureToken is string
          && request.resource.data.secureToken == resource.data.secureToken
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'returnRequested',
              'returnItems',
              'returnPhotos',
              'returnNote',
              'returnedBy',
              'returnedAt',
              'status',
              'updatedAt'
            ])
          && request.resource.data.status in ['pending', 'return_pending']
        );

      allow delete: if false;
    }

    match /processed_invoice_intents/{intentId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.intentId == intentId;
      allow delete: if false;
    }

    // ===============================
    // QR ACTIVITY LOGS
    // ===============================
    match /qr_activity_logs/{logId} {
      allow create: if
        request.resource.data.invoiceId is string &&
        request.resource.data.action is string &&
        request.resource.data.createdAt is timestamp;

      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // PUBLIC QR INVOICE SNAPSHOTS
    // ===============================
    match /invoice_qr_links/{token} {
      allow read: if true;

      allow create, update: if isAdmin()
        && request.resource.data.invoiceId is string
        && request.resource.data.token is string
        && request.resource.data.invoiceNumber is string
        && request.resource.data.items is list;

      allow delete: if false;
    }

    // ===============================
    // CUSTOMER INVOICE APPROVAL LINKS
    // ===============================
    match /invoiceApprovalLinks/{token} {
      allow get: if true;
      allow list: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'invoiceId',
          'token',
          'status',
          'createdAt',
          'expiresAt',
          'responseSubmittedAt',
          'responseType',
          'customerChanges',
          'invoiceSnapshot'
        ])
        && request.resource.data.invoiceId is string
        && request.resource.data.token == token
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.invoiceSnapshot is map;

      allow update: if isAdmin()
        ||
        (
          resource.data.token == token
          && resource.data.status == "pending"
          && request.time < resource.data.expiresAt
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'status',
              'responseSubmittedAt',
              'responseType',
              'customerChanges'
            ])
          && request.resource.data.status in ['accepted', 'modified']
          && request.resource.data.responseType in ['accepted', 'modified']
          && request.resource.data.responseType == request.resource.data.status
          && request.resource.data.responseSubmittedAt is timestamp
        );

      allow delete: if false;
    }

    // ===============================
    // NOTIFICATIONS
    // ===============================
    match /notifications/{notificationId} {
      allow read, update: if isAdmin();
      allow delete: if false;
      allow create: if isAdmin()
        ||
        (
          request.resource.data.keys().hasOnly([
            'type',
            'invoiceId',
            'responseType',
            'createdAt'
          ])
          &&
          request.resource.data.type == "invoiceApprovalResponse"
          && request.resource.data.invoiceId is string
          && request.resource.data.responseType in ['accepted', 'modified']
          && request.resource.data.createdAt is timestamp
        );
    }

    // ===============================
    // INVOICE SETTINGS
    // ===============================
    match /settings/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidDefaultOrderPriceMode();
      allow delete: if false;
    }

    match /shop_settings/{id} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // CUSTOMERS / CRM
    // ===============================
    match /customers/{customerId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // PRIVATE STORE RECORDS
    // ===============================
    match /companies/{companyId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ===============================
    // USER PROFILES / XP / BADGES
    // ===============================
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isAdmin() || isOwnProfileCreate(userId);
      allow update: if isAdmin() || isOwnProfileUpdate(userId);
      allow delete: if false;
    }

    // ===============================
    // STORE MEDIA LIBRARY
    // ===============================
    match /store_media/{mediaId} {
      allow read: if isAdmin();

      allow create, update: if isAdmin()
        && request.resource.data.companyId is string
        && request.resource.data.type is string
        && request.resource.data.name is string
        && request.resource.data.path is string
        && request.resource.data.url is string
        && request.resource.data.contentType is string
        && request.resource.data.size is number;

      allow delete: if false;
    }

    // ===============================
    // DEFAULT DENY
    // ===============================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
